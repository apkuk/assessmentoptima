# Copy to .env.local for local development.
# Do not commit real secrets.

# MongoDB Atlas connection string for application data.
MONGODB_URI=

# Optional database name. Defaults to assessmentoptima when unset.
MONGODB_DB=assessmentoptima

# Secret used to hash private result tokens before persistence.
HASH_SECRET=

# Public app URL for result links and deployment metadata.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Versioning for score interpretation and consent copy.
ASSESSMENT_VERSION=wsc-v1.0
CONSENT_VERSION=consent-v1.0

# Public aggregate/export suppression threshold.
PUBLIC_DATASET_MIN_N=10

# Enables the BYOK AI analysis UI/route when implemented.
AI_ANALYSIS_ENABLED=true

# AI analysis rate limiting. Upstash is optional but recommended on Vercel.
AI_ANALYSIS_RATE_LIMIT=8
AI_ANALYSIS_RATE_WINDOW_SECONDS=900
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional server-side OpenAI key. Leave unset until a server-funded AI feature exists.
OPENAI_API_KEY=

# Optional server-side Anthropic key. Not required for BYOK-only public analysis.
ANTHROPIC_API_KEY=
